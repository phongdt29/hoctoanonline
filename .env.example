APP_NAME=hoctoanonline
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# UI tieng Viet, code tieng Anh (SPEC §0)
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -------------------------------------------------------------
# Production: MySQL 8. Local dev (XAMPP): MariaDB 10.4 — xem docs/CLAUDE.md.
# Charset bat buoc: utf8mb4 / utf8mb4_unicode_ci
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hoctoanonline
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# --- Queue & Cache --------------------------------------------------------
# Local dev : QUEUE_CONNECTION=database, CACHE_STORE=file (khong cai Redis)
# Production: QUEUE_CONNECTION=redis,    CACHE_STORE=redis
QUEUE_CONNECTION=database
CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Storage --------------------------------------------------------------
# local (dev) / s3 (production) — anh solver OCR
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Mail -----------------------------------------------------------------
# Bat buoc cho reset password + notify parent (SPEC §7)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@hoctoanonline.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AI -------------------------------------------------------------------
# Khoa ma hoa ai_providers.api_key_encrypted (Crypt). KHONG commit gia tri that.
AI_ENCRYPT_KEY=

# Google Gemini API key. Seed doc bien nay; de trong thi seed dung key gia
# (Http::fake chay duoc, goi API that se 4xx). Lay key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
